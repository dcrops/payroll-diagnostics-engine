# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Outputs (keep structure, not data)
outputs/*
!outputs/.gitkeep

# Ignore all data by default
data/*

# Allow sample data (safe demo)
!data/sample/
!data/sample/**

# Allow demo client (portfolio example)
!data/clients/
!data/clients/kaggle_demo/
!data/clients/kaggle_demo/**

# Ignore raw files (can be large / sensitive)
data/clients/*/*/raw/*
!data/clients/kaggle_demo/*/raw/*.csv

# Ignore processed outputs (can regenerate)
data/clients/*/*/processed/*

# BUT allow small demo processed files if you want
!data/clients/kaggle_demo/*/processed/*.csv

# IDE
.vscode/
.idea/

# Packaging artifacts
*.egg-info/

# Output artefacts
outputs/*
!outputs/.gitkeep

# Python cache
__pycache__/
*.py[cod]
*.pyo

# pytest cache
.pytest_cache/